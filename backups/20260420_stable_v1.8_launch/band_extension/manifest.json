{
  "manifest_version": 3,
  "name": "버스기사다~얍: 밴드 자동 수집기",
  "version": "1.0.0",
  "description": "네이버 밴드 배차 정보를 추출하여 버스기사 앱으로 안전하게 전송합니다.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://band.us/*"],
  "content_scripts": [
    {
      "matches": ["*://band.us/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
